/*FOR EACH item WHERE item.fm-codigo = "202010" NO-LOCK,
    EACH movto-estoq WHERE item.it-codigo = movto-estoq.it-codigo 
                       AND movto-estoq.dt-criacao = TODAY NO-LOCK BY item.fm-codigo.*/
                       
FOR EACH item WHERE item.it-codigo >= c-it-cod-ini    
					item.it-codigo <= c-it-cod-fin    
					item.fm-codigo >= c-fm-cod-ini    
					item.fm-codigo <= c-fm-cod-fin NO-LOCK,
	EACH movto-estoq OF item WHERE movto-estoq.it-codigo = item.it-codigo
							   AND movto-estoq.dt-criacao  >= c-dt-movto-ini
								   movto-estoq.dt-criacao  <= c-dt-movto-fin
								   movto-estoq.cod-estabel >= c-cod-estab-ini 
					               movto-estoq.cod-estabel >= c-cod-estab-fin NO-LOCK,
	EACH ord-prod OF movto-estoq WHERE ord-prod.nr-ord-produ = movto-estoq.nr-ord-produ 
								   AND ord-prod.nr-linha >= c-nr-linha-ini
								   AND ord-prod.nr-linha <= c-nr-linha-fin
								   AND ord-prod.cd-planejado >=	c-planejador-ini
								   AND ord-prod.cd-planejado <=	c-planejador-fin NO-LOCK BY item.fm-codigo. 
  
		  CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num    = 1
                       tt-dados.planilha-num   = 1
                       tt-dados.celula-coluna  = 1
                       tt-dados.celula-linha   = i-linha
                       tt-dados.celula-formato = "@"
                       tt-dados.celula-valor   = item.fm-codigo.
                
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num   = 1
                       tt-dados.planilha-num  = 1
                       tt-dados.celula-coluna = 2
                       tt-dados.celula-linha  = i-linha
                       tt-dados.celula-valor  = item.it-codigo.
                    
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num   = 1
                       tt-dados.planilha-num  = 1
                       tt-dados.celula-coluna = 3
                       tt-dados.celula-linha  = i-linha
                       tt-dados.celula-valor  = item.desc-item.
					   
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num   = 1
                       tt-dados.planilha-num  = 1
                       tt-dados.celula-coluna = 4
                       tt-dados.celula-linha  = i-linha
                       tt-dados.celula-valor  = item.un.
                       
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num   = 1
                       tt-dados.planilha-num  = 1
                       tt-dados.celula-coluna = 5
                       tt-dados.celula-linha  = i-linha
                       tt-dados.celula-formato = "@"
                       tt-dados.celula-valor  = movto-estoq.cod-depos.
                       
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num   = 1
                       tt-dados.planilha-num  = 1
                       tt-dados.celula-coluna = 6
                       tt-dados.celula-linha  = i-linha
                       tt-dados.celula-valor  = STRING(movto-estoq.dt-criacao).
             
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num   = 1
                       tt-dados.planilha-num  = 1
                       tt-dados.celula-coluna = 7
                       tt-dados.celula-linha  = i-linha
                       tt-dados.celula-valor  = STRING(movto-estoq.nr-ord-produ).
                       
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num    = 1
                       tt-dados.planilha-num   = 1
                       tt-dados.celula-coluna  = 8
                       tt-dados.celula-linha   = i-linha
                       tt-dados.celula-formato = "@"
                       tt-dados.celula-valor   = movto-estoq.referencia.
                       
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num    = 1
                       tt-dados.planilha-num   = 1
                       tt-dados.celula-coluna  = 9
                       tt-dados.celula-linha   = i-linha
                       tt-dados.celula-formato = "@"
                       tt-dados.celula-valor   = STRING(movto-estoq.esp-docto).
                       
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num    = 1
                       tt-dados.planilha-num   = 1
                       tt-dados.celula-coluna  = 10
                       tt-dados.celula-linha   = i-linha
                       tt-dados.celula-formato = "@"
                       tt-dados.celula-valor   = movto-estoq.lote.
                       
                CREATE tt-dados.
                ASSIGN tt-dados.arquivo-num    = 1
                       tt-dados.planilha-num   = 1
                       tt-dados.celula-coluna  = 11
                       tt-dados.celula-linha   = i-linha
                       tt-dados.celula-formato = "@"
                       tt-dados.celula-valor   = STRING(movto-estoq.quantidade).  
                       
                i-linha = i-linha + 1.
    
END.

