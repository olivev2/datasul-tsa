DEFINE SHARED VARIABLE c-dt-movto-ini    AS DATE FORMAT "99/99/9999" NO-UNDO.  
DEFINE SHARED VARIABLE c-dt-movto-fin    AS DATE FORMAT "99/99/9999" NO-UNDO. 
DEFINE SHARED VARIABLE c-it-cod-ini      AS CHAR FORMAT "x(16)" NO-UNDO.
DEFINE SHARED VARIABLE c-it-cod-fin      AS CHAR FORMAT "x(16)" NO-UNDO.
DEFINE SHARED VARIABLE c-fm-cod-ini      AS CHAR FORMAT "x(8)" NO-UNDO.
DEFINE SHARED VARIABLE c-fm-cod-fin      AS CHAR FORMAT "x(8)" NO-UNDO.
DEFINE SHARED VARIABLE c-planejador-ini  AS CHAR FORMAT "x(12)" NO-UNDO.
DEFINE SHARED VARIABLE c-planejador-fin  AS CHAR FORMAT "x(12)" NO-UNDO.
DEFINE SHARED VARIABLE c-cod-estab-ini   AS CHAR FORMAT "X(5)" NO-UNDO.
DEFINE SHARED VARIABLE c-cod-estab-fin   AS CHAR FORMAT "X(5)" NO-UNDO.
DEFINE SHARED VARIABLE c-nr-linha-ini    AS INT  NO-UNDO.
